# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# bundle analyzer
.next/
analyze/

# prettier
node_modules/

# =============================================================================
# Safety Patterns
# =============================================================================

# Agent output / debugging artifacts
agent-output*
notes*
todo*

# Heap snapshots from Chrome DevTools
*.heapsnapshot

# Screenshots during testing
*.screenshot.*

# Generic temp directories
tmp/
temp/

# pnpm debug logs (if pnpm is used)
.pnpm-debug.log*

# Local override configs
*.local

# Supabase CLI local working directory (machine-local config)
supabase/
