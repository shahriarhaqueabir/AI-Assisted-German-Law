{
  "$schema": "https://opencode.ai/config.json",

  // Project-specific instructions and rules
  "instructions": ["AGENTS.md"],

  // Project-specific slash commands
  "command": {
    "import-laws": {
      "description": "Download and process all 6,000+ German laws",
      "template": "Run the full import pipeline: python download_de_laws.py && python process_de_laws.py"
    },
    "translate": {
      "description": "Translate law data using local AI",
      "template": "Translate laws: python unified_translator.py"
    },
    "vector-index": {
      "description": "Rebuild the vector search index",
      "template": "Rebuild search index: python vector_search.py"
    },
    "dedupe": {
      "description": "Deduplicate processed law data",
      "template": "Run deduplication: python dedupe_processed_data.py"
    },
    "logs": {
      "description": "View application logs",
      "template": "View logs: python view_logs.ps1"
    }
  }
}
