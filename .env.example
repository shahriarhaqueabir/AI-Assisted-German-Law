# German Law Vault - Environment Configuration Template
# Copy this file to .env and customize as needed
# cp .env.example .env (Linux/macOS)
# copy .env.example .env (Windows)

# =============================================================================
# AI / Ollama Configuration
# =============================================================================

# Ollama API endpoint (default: local Ollama installation)
OLLAMA_URL=http://127.0.0.1:11434/api/generate

# Ollama model to use for AI features
# Options: llama3.2, llama3.1, mistral, etc.
OLLAMA_MODEL=qwen2.5:1.5b

# Timeout for AI requests (in seconds)
OLLAMA_TIMEOUT=120

# Maximum number of retry attempts for AI requests
OLLAMA_MAX_RETRIES=3

# Backoff factor for retry delays (exponential backoff)
OLLAMA_RETRY_BACKOFF=1.0

# =============================================================================
# Cache Configuration
# =============================================================================

# Maximum size of query expansion cache (number of entries)
EXPANSION_CACHE_SIZE=1000

# Interval for saving translation cache to disk (in seconds)
TRANSLATION_SAVE_INTERVAL=30

# =============================================================================
# Server Configuration
# =============================================================================

# Server host (DO NOT change to 0.0.0.0 for production without security measures)
SERVER_HOST=127.0.0.1

# Server port
SERVER_PORT=5000

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log directory (relative to project root)
LOG_DIR=Logs

# =============================================================================
# Data Directories
# =============================================================================

# Directory for raw downloaded XML files
RAW_DATA_DIR=./de_federal_raw

# Directory for processed JSON files
JSON_DATA_DIR=./de_federal_json

# Directory for translations (if enabled)
TRANSLATION_DIR=./de_federal_translations

# Search index file path
SEARCH_INDEX_FILE=./search_index.json

# =============================================================================
# Optional Features
# =============================================================================

# Enable/disable AI features (true/false)
AI_ENABLED=true

# Enable debug mode (true/false) - DO NOT enable in production
DEBUG_MODE=false

# Enable rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# =============================================================================
# Advanced Configuration
# =============================================================================

# BM25 parameters for search ranking
BM25_K1=1.5
BM25_B=0.75

# Maximum results per page
MAX_RESULTS_PER_PAGE=5

# Maximum search results returned
MAX_SEARCH_RESULTS=50

# =============================================================================
# Notes
# =============================================================================
#
# 1. This file should NOT be committed to version control
# 2. Create a .env file from this template for your local configuration
# 3. Sensitive values (API keys, passwords) should never be committed
# 4. Environment variables take precedence over .env file values
#
# =============================================================================
