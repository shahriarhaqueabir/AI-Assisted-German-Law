# =============================================================================
# German Law Vault - Environment Configuration Template
# =============================================================================

# --- Supabase (Cloud Database & Auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_DB_PASSWORD=your-db-password

# --- Qdrant (Vector Search) ---
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-api-key

# --- Local Broker & AI (Optional) ---
# Set this to the local broker address for AI reasoning
NEXT_PUBLIC_BROKER_URL=http://localhost:9090
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b

# --- Legacy Backend (Ollama/SQLite) ---
# Used if running the original Flask implementation
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3

# --- Logging & Data ---
LOG_LEVEL=INFO
RAW_DATA_DIR=./de_federal_raw
JSON_DATA_DIR=./de_federal_json
